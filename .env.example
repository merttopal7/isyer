# ── Veritabanı ────────────────────────────────────────────────
DB_CLIENT=better-sqlite3
DB_FILENAME=./dev.sqlite3

# PostgreSQL (production)
# DB_CLIENT=pg
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=berber_db
# DB_USER=postgres
# DB_PASSWORD=your_password

# ── Auth ───────────────────────────────────────────────────────
JWT_SECRET=change-this-secret-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# ── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Google OAuth ───────────────────────────────────────────────
# Authorized redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Deployment ─────────────────────────────────────────────────
# false → path-based routing  (/isletme/[slug]/[sayfa])
# true  → subdomain routing   ([slug].alanadi.com/[sayfa])
NEXT_PUBLIC_PRODUCTION=false
NEXT_PUBLIC_BASE_DOMAIN=alanadi.com
