    "knex": "^3.2.10",
    "pg": "^8.13.3",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
